{
  "name": "pomodolldoll",
  "productName": "POMODOLLDOLL",
  "version": "1.1.0",
  "description": "고양이·강아지와 함께하는 뽀모도로 & 태스크 데스크탑 앱",
  "author": {
    "name": "기린",
    "email": "promptato@gmail.com"
  },
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "icon": "electron gen-icon-png.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "png2icons": "^2.0.1"
  },
  "build": {
    "appId": "com.kirin.cozypomodoro",
    "productName": "POMODOLLDOLL",
    "copyright": "© 2026 기린",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "POMODOLLDOLL",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "runAfterFinish": true,
      "menuCategory": "POMODOLLDOLL"
    },
    "portable": {
      "artifactName": "POMODOLLDOLL-portable-${version}.exe"
    }
  }
}
